# PostgreSQL
POSTGRES_USER=propOS
POSTGRES_PASSWORD=localdevpassword
POSTGRES_DB=propos_dev
DATABASE_URL=postgresql://propOS:localdevpassword@localhost:5432/propos_dev

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=localdevpassword

# JWT
# Development: set JWT_SECRET to any string
# Production: use RS256 keys — openssl genrsa -out jwt_private.pem 2048
JWT_SECRET=dev-secret-change-in-production
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_EXPIRY=2592000

# App
NODE_ENV=development
API_PORT=3001
WEB_PORT=3000
CORS_ORIGIN=http://localhost:3000

# Object Storage (MinIO for local dev)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=propos-local
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# Seed Control
ALLOW_PRODUCTION_SEED=false
